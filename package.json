{
  "name": "nis-school-crm",
  "version": "0.1.0",
  "private": true,
  "description": "NIS School CRM monorepo — backend (NestJS), frontend (React+Vite), shared types",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @nis/shared",
    "build": "npm run build:shared && npm run build --workspace @nis/api && npm run build --workspace @nis/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"{apps,packages}/*/{src,test}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{apps,packages}/*/{src,test}/**/*.{ts,tsx,json,md}\"",
    "dev:api": "npm run dev --workspace @nis/api",
    "dev:web": "npm run dev --workspace @nis/web",
    "build:api": "npm run build:shared && npm run build --workspace @nis/api",
    "build:web": "npm run build:shared && npm run build --workspace @nis/web",
    "test:api": "npm run test --workspace @nis/api",
    "test:web": "npm run test --workspace @nis/web",
    "migration:run": "npm run migration:run --workspace @nis/api",
    "migration:generate": "npm run migration:generate --workspace @nis/api",
    "db:seed": "npm run db:seed --workspace @nis/api",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
