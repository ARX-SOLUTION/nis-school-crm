# ------------------------------------------------------------------------------
# NIS School CRM — example environment
# Copy to .env and fill with real values. NEVER commit a filled .env.
# ------------------------------------------------------------------------------

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# ---- Database ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=nis_admin
DB_PASSWORD=change_me_strong
DB_NAME=nis_crm
DB_SSL=false

# ---- Redis -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong
REDIS_DB=0

# ---- RabbitMQ ----------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=nis_mq
RABBITMQ_PASSWORD=change_me_strong
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://nis_mq:change_me_strong@localhost:5672
# Management UI — expose on localhost only in dev, block at firewall in shared networks
RABBITMQ_MGMT_PORT=15672

# ---- JWT ---------------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_64_hex_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Security ----------------------------------------------------------------
BCRYPT_COST=12
CORS_ORIGINS=http://localhost:5173
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# Stricter limits on /auth/login (handled in controller):
AUTH_THROTTLE_TTL=900
AUTH_THROTTLE_LIMIT=5

# ---- Telegram bot (Stage 6) --------------------------------------------------
# Get from @BotFather. Empty value disables the bot in dev.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ---- Seed admin --------------------------------------------------------------
SEED_SUPER_ADMIN_EMAIL=admin@nis.uz
SEED_SUPER_ADMIN_PASSWORD=ChangeMeOnFirstLogin!
SEED_SUPER_ADMIN_NAME=Super Admin
